{
    "__comment_info": {
        "style": "Material 2 Dark (Grey & Orange)",
        "accent": "#FF9800",
        "background": "#121212"
    },
    "QMainWindow": {
        "background-color": "#121212",
        "font-family": "Roboto",
        "font-size": "13px",
        "color": "#FFFFFF"
    },
    "QWidget#centralwidget, QWidget#Main_widget": {
        "background-color": "#121212"
    },
    "QFrame#left_frame": {
        "background-color": "#1E1E1E",
        "border-right": "1px solid #333333"
    },
    "QFrame#right_frame": {
        "background-color": "#000000",
        "border-left": "1px solid #333333"
    },
    "QFrame[objectName^=\"plugin_frame_\"]": {
        "background-color": "#242424",
        "border": "1px solid #3D3D3D",
        "border-radius": "12px",
        "margin": "2px"
    },
    "QGroupBox": {
        "background-color": "#1E1E1E",
        "border": "1px solid #333333",
        "border-radius": "12px",
        "margin-top": "15px",
        "padding-top": "10px",
        "font-weight": "bold",
        "color": "#FF9800"
    },
    "QGroupBox::title": {
        "subcontrol-origin": "margin",
        "subcontrol-position": "top center",
        "padding": "0 10px",
        "background-color": "#1E1E1E"
    },
    "QPushButton": {
        "background-color": "#333333",
        "border": "1px solid #444444",
        "border-radius": "8px",
        "color": "#FFFFFF",
        "padding": "6px",
        "min-height": "20px"
    },
    "QPushButton:hover": {
        "background-color": "#444444",
        "border": "1px solid #FF9800"
    },
    "QPushButton:pressed": {
        "background-color": "#E68900",
        "color": "#000000"
    },
    "QPushButton:checked": {
        "background-color": "#FF9800",
        "color": "#000000",
        "border": "1px solid #FFFFFF"
    },
    "QToolButton": {
        "background-color": "#333333",
        "border": "1px solid #454545",
        "border-radius": "8px",
        "color": "#FFFFFF",
        "padding": "6px"
    },
    "QToolButton:hover": {
        "background-color": "#444444",
        "border": "1px solid #FF9800"
    },
    "QToolButton:pressed": {
        "background-color": "#E68900",
        "color": "#000000"
    },
    "QLineEdit": {
        "background-color": "#242424",
        "border": "none",
        "border-bottom": "2px solid #555555",
        "border-top-left-radius": "4px",
        "border-top-right-radius": "4px",
        "color": "#FFFFFF",
        "padding": "5px"
    },
    "QLineEdit:focus": {
        "border-bottom": "2px solid #FF9800",
        "background-color": "#2F2F2F"
    },
    "QLineEdit[objectName^=\"plugin_led_\"]": {
        "background-color": "#121212",
        "border": "1px solid #333333",
        "border-radius": "4px",
        "color": "#FF9800",
        "font-weight": "bold"
    },
    "QToolButton[objectName^=\"plugin_add_toolB_\"]": { "qproperty-icon": "url(resources/ico/ico_add.png)" },
    "QToolButton[objectName^=\"plugin_reload_toolB_\"]": { "qproperty-icon": "url(resources/ico/ico_reload.png)" },
    "QToolButton[objectName^=\"plugin_delete_toolB_\"]": { "qproperty-icon": "url(resources/ico/ico_delete.png)" },
    "__comment_new_icons": "For future SVG icons, replace above lines with: QToolButton[objectName^='plugin_add_'] { qproperty-icon: url(resources/ico/material/add.svg) }",
    "status_connected": {
        "background-color": "#1B5E20",
        "color": "#FFFFFF",
        "border": "none"
    },
    "status_disconnected": {
        "background-color": "#B71C1C",
        "color": "#FFFFFF",
        "border": "none"
    },
    "animation": {
        "duration": 150,
        "scale_factor": 0.95,
        "easing_curve": "OutCubic"
    }
}
