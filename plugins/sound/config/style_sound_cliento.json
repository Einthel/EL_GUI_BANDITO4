{
  "QMainWindow": {
    "background-color": "#1e1e1e",
    "color": "#ffffff"
  },
  "QFrame#sound_frame": {
    "background-color": "#252526",
    "border": "1px solid #333333",
    "border-radius": "8px"
  },
  "QFrame#volume_frame, QFrame#eq_frame, QFrame#audio_device_frame": {
    "background-color": "#2d2d30",
    "border": "1px solid #3f3f46",
    "border-radius": "5px"
  },
  "QGroupBox": {
    "border": "2px solid #3e3e42",
    "border-radius": "5px",
    "margin-top": "10px",
    "font-weight": "bold",
    "color": "#007acc"
  },
  "QGroupBox::title": {
    "subcontrol-origin": "margin",
    "left": "10px",
    "padding": "0 3px"
  },
  "QLabel": {
    "color": "#cccccc",
    "font-weight": "bold",
    "border": "none"
  },
  "QLineEdit": {
    "background-color": "#333333",
    "border": "1px solid #555555",
    "color": "#eeeeee",
    "padding": "5px",
    "border-radius": "3px"
  },
  "QProgressBar": {
    "border": "1px solid #444444",
    "border-radius": "2px",
    "background-color": "#121212",
    "text-align": "center"
  },
  "QProgressBar::chunk": {
    "background-color": "qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #4caf50, stop:1 #2e7d32)",
    "margin": "1px"
  },
  "QProgressBar#mic_level_pBar": {
    "background-color": "#1a1a1a"
  },
  "QSlider:vertical": {
    "width": "40px",
    "margin": "4px 0"
  },
    "QSlider::groove:vertical": {
    "background": "#121212",
    "width": "12px",
    "border": "1px solid #444444",
    "border-radius": "6px"
  },
    "QSlider::handle:vertical": {
    "background": "qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #575757, stop:0.5 #8a8a8a, stop:1 #575757)",
    "border": "1px solid #111111",
    "height": "20px",
    "width": "30px",
    "margin": "0 -10px",
    "border-radius": "4px"
  },
  "QSlider::handle:vertical:hover": {
    "background": "qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #007acc, stop:0.5 #3ea6ff, stop:1 #007acc)",
    "border": "1px solid #005a9e"
  },
  "QSlider::add-page:vertical": {
    "background": "#333333",
    "border-radius": "5px"
  },
  "QSlider::sub-page:vertical": {
    "background": "#1a1a1a",
    "border-radius": "5px"
  },
  "QToolButton": {
    "background-color": "#3e3e42",
    "border": "1px solid #555555",
    "border-radius": "4px",
    "color": "#ffffff",
    "padding": "5px"
  },
  "QToolButton:hover": {
    "background-color": "#505050",
    "border": "1px solid #007acc"
  },
  "QToolButton:pressed": {
    "background-color": "#007acc"
  },
  "QToolButton:checked": {
    "background-color": "#007acc",
    "border": "2px solid #3ea6ff"
  },
  "QToolButton#mic_mute_toolB": {
    "qproperty-icon": "url(plugins/sound/resources/sys/ico_mic_on.png)"
  },
  "QToolButton#mic_mute_toolB:checked": {
    "qproperty-icon": "url(plugins/sound/resources/sys/ico_mic_off.png)"
  },
  "QToolButton#sound_mute_toolB": {
    "qproperty-icon": "url(plugins/sound/resources/sys/ico_vol_on.png)"
  },
  "QToolButton#sound_mute_toolB:checked": {
    "qproperty-icon": "url(plugins/sound/resources/sys/ico_vol_off.png)"
  }
}