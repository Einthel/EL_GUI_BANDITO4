{
    "QWidget#tune_cliento": {
        "background-color": "#2b2b2b",
        "color": "#ffffff"
    },
    "QFrame#tune_frame": {
        "border": "1px solid #3f3f3f",
        "background-color": "#2b2b2b"
    },
    "QFrame#volume_frame, QFrame#eq_frame, QFrame#audio_device_frame": {
        "border": "1px solid #3f3f3f",
        "border-radius": "5px",
        "background-color": "#333333"
    },
    "QLabel": {
        "color": "#e0e0e0",
        "font-weight": "bold"
    },
    "QLabel#mic_lable, QLabel#sound_lable, QLabel#other_lable": {
        "background-color": "#444444",
        "border": "1px solid #555555",
        "border-radius": "3px"
    },
    "QProgressBar": {
        "border": "1px solid #555555",
        "border-radius": "2px",
        "background-color": "#1e1e1e",
        "text-align": "center"
    },
    "QProgressBar::chunk": {
        "background-color": "#0078d7"
    },
    "QSlider::groove:vertical": {
        "background": "#1e1e1e",
        "width": "6px",
        "border-radius": "3px"
    },
    "QSlider::handle:vertical": {
        "background": "#0078d7",
        "border": "1px solid #005a9e",
        "height": "15px",
        "margin": "0 -4px",
        "border-radius": "7px"
    },
    "QToolButton#mic_mute_toolB": {
        "qproperty-icon": "url(plugins/tune/resources/sys/ico_mic_on.png)",
        "qproperty-iconSize": "70px 70px"
    },
      "QToolButton#mic_mute_toolB:checked": {
    "qproperty-icon": "url(plugins/tune/resources/sys/ico_mic_off.png)"
  },
    "QToolButton#sound_mute_toolB": {
        "qproperty-icon": "url(plugins/tune/resources/sys/ico_vol_on.png)"
    },
    "QToolButton#sound_mute_toolB:checked": {
        "qproperty-icon": "url(plugins/tune/resources/sys/ico_vol_off.png)"
    },
    "QToolButton#mic_toolB": {
        "qproperty-icon": "url(plugins/tune/resources/sys/ico_mic_on.png)"
    },
    "QToolButton#mic_toolB:checked": {
        "qproperty-icon": "url(plugins/tune/resources/sys/ico_mic_off.png)"
    },
    "QToolButton": {
        "background-color": "#444444",
        "border": "1px solid #555555",
        "border-radius": "5px",
        "padding": "5px"
    },
    "QToolButton:hover": {
        "background-color": "#555555"
    },
    "QToolButton:pressed": {
        "background-color": "#0078d7"
    },
    "QLineEdit": {
        "background-color": "#1e1e1e",
        "border": "1px solid #555555",
        "color": "#ffffff",
        "padding": "2px"
    },
    "QLineEdit[selectedDevice=\"true\"]": {
        "border": "2px solid #4CAF50",
        "background-color": "rgba(76, 175, 80, 40)"
    },
    "QGroupBox": {
        "border": "1px solid #555555",
        "border-radius": "5px",
        "margin-top": "10px",
        "font-weight": "bold",
        "color": "#0078d7"
    },
    "QGroupBox::title": {
        "subcontrol-origin": "margin",
        "left": "10px",
        "padding": "0 3px"
    }
}
